---
import MainLayout from './MainLayout.astro'
import PageTitle from '../PageTitle.astro'
import graphData from '../../data/dependency-graph.json'

interface Props {
  title: string
  status?: string
  gaStructure?: string
  targetDerivation?: string
  priority?: string
  hasOverview?: boolean
}

const { title, status, gaStructure, targetDerivation, priority, hasOverview } = Astro.props
const base = import.meta.env.BASE_URL.replace(/\/$/, '')

const statusClass = status ? `status-${status}` : ''

const titleMap: Record<string, string> = {}
for (const node of (graphData as any).nodes) {
  titleMap[node.id] = node.title
}

function getTitle(id: string): string {
  return titleMap[id] || id.split('/').pop() || id
}
---

<MainLayout title={`${title} — Geometric Algebra`}>
  <article>
    <div class="ga-banner">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
      Geometric Algebra Exploration &mdash; supplementary analysis, not part of the core derivation chain
    </div>
    <PageTitle title={title}>
      <div class="title-badges">
        {status && <span class={`status-badge ${statusClass}`}>{status}</span>}
        {gaStructure && <span class="ga-structure-badge">{gaStructure}</span>}
        {priority && <span class={`ga-priority-badge ga-priority-${priority}`}>{priority} priority</span>}
      </div>
    </PageTitle>

    {targetDerivation && (
      <div class="ga-target">
        <h4>Analyzes Derivation</h4>
        <a href={`${base}/derivations/${targetDerivation}`}>{getTitle(targetDerivation)}</a>
      </div>
    )}

    <slot />
  </article>
</MainLayout>

{hasOverview && (
  <script is:inline>
    (function initGATabs() {
      const article = document.querySelector('article')
      if (!article) {
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', initGATabs)
        }
        return
      }

      const overviewH2 = article.querySelector('h2#overview')
      if (!overviewH2) return

      const children = Array.from(article.children)

      // Slot content starts after structural elements (banner, header, ga-target, scripts/styles)
      let slotStart = 0
      for (let i = 0; i < children.length; i++) {
        const el = children[i]
        const isStructural = (
          el.tagName === 'HEADER' ||
          el.classList.contains('page-title-bar') ||
          el.classList.contains('ga-banner') ||
          el.classList.contains('ga-target') ||
          el.tagName === 'STYLE' ||
          el.tagName === 'SCRIPT'
        )
        if (isStructural) {
          slotStart = i + 1
        } else {
          break
        }
      }

      const slotElements = children.slice(slotStart)
      if (slotElements.length === 0) return

      // Partition into overview and derivation (GA analysis) content
      const overviewNodes = []
      const derivationNodes = []
      let inOverview = false

      for (const el of slotElements) {
        if (el === overviewH2) {
          inOverview = true
          overviewNodes.push(el)
          continue
        }
        if (inOverview && el.tagName === 'H2') {
          inOverview = false
          derivationNodes.push(el)
          continue
        }
        if (inOverview) {
          overviewNodes.push(el)
        } else {
          derivationNodes.push(el)
        }
      }

      if (overviewNodes.length === 0) return

      // Build tab bar
      const tabBar = document.createElement('div')
      tabBar.className = 'derivation-tabs'
      tabBar.setAttribute('role', 'tablist')

      const tabOverview = document.createElement('button')
      tabOverview.className = 'derivation-tab derivation-tab--active'
      tabOverview.setAttribute('role', 'tab')
      tabOverview.setAttribute('aria-selected', 'true')
      tabOverview.setAttribute('id', 'tab-overview')
      tabOverview.setAttribute('aria-controls', 'panel-overview')
      tabOverview.textContent = 'Overview'

      const tabDerivation = document.createElement('button')
      tabDerivation.className = 'derivation-tab'
      tabDerivation.setAttribute('role', 'tab')
      tabDerivation.setAttribute('aria-selected', 'false')
      tabDerivation.setAttribute('id', 'tab-derivation')
      tabDerivation.setAttribute('aria-controls', 'panel-derivation')
      tabDerivation.textContent = 'Derivation'

      tabBar.appendChild(tabOverview)
      tabBar.appendChild(tabDerivation)

      // Build panels
      const panelOverview = document.createElement('div')
      panelOverview.className = 'derivation-panel derivation-panel--active'
      panelOverview.setAttribute('role', 'tabpanel')
      panelOverview.setAttribute('id', 'panel-overview')
      panelOverview.setAttribute('aria-labelledby', 'tab-overview')

      const panelDerivation = document.createElement('div')
      panelDerivation.className = 'derivation-panel'
      panelDerivation.setAttribute('role', 'tabpanel')
      panelDerivation.setAttribute('id', 'panel-derivation')
      panelDerivation.setAttribute('aria-labelledby', 'tab-derivation')
      panelDerivation.hidden = true

      for (const node of overviewNodes) panelOverview.appendChild(node)
      for (const node of derivationNodes) panelDerivation.appendChild(node)

      article.appendChild(tabBar)
      article.appendChild(panelOverview)
      article.appendChild(panelDerivation)

      // Tab switching
      function switchTab(activeId) {
        const isOverview = activeId === 'overview'
        tabOverview.classList.toggle('derivation-tab--active', isOverview)
        tabOverview.setAttribute('aria-selected', String(isOverview))
        tabDerivation.classList.toggle('derivation-tab--active', !isOverview)
        tabDerivation.setAttribute('aria-selected', String(!isOverview))
        panelOverview.classList.toggle('derivation-panel--active', isOverview)
        panelOverview.hidden = !isOverview
        panelDerivation.classList.toggle('derivation-panel--active', !isOverview)
        panelDerivation.hidden = isOverview
      }

      tabOverview.addEventListener('click', function() { switchTab('overview') })
      tabDerivation.addEventListener('click', function() { switchTab('derivation') })

      // Handle URL hash targeting
      function handleHash() {
        var hash = window.location.hash
        if (!hash) return
        var target = document.getElementById(hash.slice(1))
        if (!target) return
        if (panelDerivation.contains(target)) {
          switchTab('derivation')
          requestAnimationFrame(function() { target.scrollIntoView({ behavior: 'smooth' }) })
        } else if (panelOverview.contains(target)) {
          switchTab('overview')
          requestAnimationFrame(function() { target.scrollIntoView({ behavior: 'smooth' }) })
        }
      }

      handleHash()
      window.addEventListener('hashchange', handleHash)
    })()
  </script>
)}

<style>
  .ga-banner {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.75rem;
    color: var(--color-text-muted);
    padding: 0.5rem 0.75rem;
    margin-bottom: 1.5rem;
    background: color-mix(in srgb, var(--color-border) 30%, transparent);
    border-radius: 6px;
    border-left: 3px solid var(--color-text-muted);
  }
  .ga-banner svg {
    flex-shrink: 0;
    opacity: 0.6;
  }
  .title-badges {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    margin-top: 0.35rem;
  }
  .ga-structure-badge {
    display: inline-block;
    margin-left: 0.5rem;
    padding: 0.15rem 0.6rem;
    font-size: 0.7rem;
    font-weight: 700;
    font-family: 'SF Mono', 'Fira Code', 'Fira Mono', monospace;
    color: #7c3aed;
    background: color-mix(in srgb, #7c3aed 10%, transparent);
    border-radius: 9999px;
    vertical-align: middle;
    letter-spacing: 0.02em;
  }
  .ga-priority-badge {
    display: inline-block;
    margin-left: 0.5rem;
    padding: 0.15rem 0.5rem;
    font-size: 0.65rem;
    font-weight: 600;
    text-transform: uppercase;
    border-radius: 9999px;
    vertical-align: middle;
    letter-spacing: 0.03em;
  }
  .ga-priority-high {
    color: #16a34a;
    background: color-mix(in srgb, #16a34a 10%, transparent);
  }
  .ga-priority-moderate {
    color: #ca8a04;
    background: color-mix(in srgb, #ca8a04 10%, transparent);
  }
  .ga-priority-low {
    color: var(--color-text-muted);
    background: color-mix(in srgb, var(--color-border) 50%, transparent);
  }
  .ga-target {
    padding: 0.75rem 1rem;
    margin-bottom: 1.5rem;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    background: var(--color-surface);
  }
  .ga-target h4 {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
    margin: 0 0 0.3rem;
  }
  .ga-target a {
    color: var(--color-accent);
    text-decoration: none;
    font-weight: 600;
    font-size: 0.95rem;
  }
  .ga-target a:hover {
    text-decoration: underline;
  }
</style>
