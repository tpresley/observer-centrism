---
import MainLayout from '../components/layouts/MainLayout.astro'
import PageTitle from '../components/PageTitle.astro'

const base = import.meta.env.BASE_URL.replace(/\/$/, '')
---

<MainLayout title="Site Map">
  <PageTitle title="Site Map" />
  <p>Everything on this site, organized by section.</p>

  <div class="sm-grid">
    <div class="sm-section">
      <h2>Start Here</h2>
      <a href={`${base}/note-to-researchers`} class="sm-link">
        <strong>Note to Researchers</strong>
        <span>What this framework is, what's honestly open, and where to begin.</span>
      </a>
      <a href={`${base}/mysteries`} class="sm-link">
        <strong>Mysteries of Physics</strong>
        <span>Fundamental questions in physics and how the framework addresses each one.</span>
      </a>
      <a href={`${base}/guide/`} class="sm-link">
        <strong>Guide</strong>
        <span>A narrative walkthrough from first principles to predictions.</span>
      </a>
      <a href={`${base}/domains/`} class="sm-link">
        <strong>Domain Overviews</strong>
        <span>The framework's contributions by research area: quantum foundations, cosmology, particle physics, holography.</span>
      </a>
    </div>

    <div class="sm-section">
      <h2>Framework Structure</h2>
      <a href={`${base}/derivations/`} class="sm-link">
        <strong>Derivations Index</strong>
        <span>All derivations organized by topic group, with status and dependency information.</span>
      </a>
      <a href={`${base}/map`} class="sm-link">
        <strong>Derivation Map</strong>
        <span>Interactive dependency graph showing how derivations connect axioms to predictions.</span>
      </a>
      <a href={`${base}/predictions/`} class="sm-link">
        <strong>Predictions</strong>
        <span>Testable consequences that distinguish this framework from existing theories.</span>
      </a>
    </div>

    <div class="sm-section">
      <h2>Inventories</h2>
      <a href={`${base}/theorems`} class="sm-link">
        <strong>Theorems</strong>
        <span>All named theorems proved across the derivation chain, with Lean 4 verification badges.</span>
      </a>
      <a href={`${base}/postulates`} class="sm-link">
        <strong>Structural Postulates</strong>
        <span>Explicit assumptions beyond the three axioms, with justifications and derivation status.</span>
      </a>
      <a href={`${base}/open-gaps`} class="sm-link">
        <strong>Open Gaps</strong>
        <span>Unresolved questions, limitations, and potential extensions cataloged across all derivations.</span>
      </a>
      <a href={`${base}/references`} class="sm-link">
        <strong>References</strong>
        <span>Academic works cited across the framework, with links to original papers.</span>
      </a>
    </div>

    <div class="sm-section">
      <h2>Explorations</h2>
      <a href={`${base}/geometric-algebra/`} class="sm-link">
        <strong>Geometric Algebra</strong>
        <span>Supplementary analyses recasting framework derivations in Clifford algebra language.</span>
      </a>
    </div>

    <div class="sm-section">
      <h2>Tools</h2>
      <a href={`${base}/search`} class="sm-link">
        <strong>Search</strong>
        <span>Full-text search across all derivations, predictions, and guides.</span>
      </a>
    </div>
  </div>
</MainLayout>

<style>
  .sm-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    margin-top: 1rem;
  }

  @media (max-width: 700px) {
    .sm-grid { grid-template-columns: 1fr; }
  }

  .sm-section h2 {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
    margin: 0 0 0.75rem;
    padding: 0;
    border: none;
  }

  .sm-link {
    display: block;
    padding: 0.75rem 1rem;
    margin-bottom: 0.5rem;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    background: var(--color-surface);
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s;
  }

  .sm-link:hover {
    border-color: var(--color-accent);
  }

  .sm-link strong {
    display: block;
    font-size: 0.95rem;
    color: var(--color-accent);
    margin-bottom: 0.2rem;
  }

  .sm-link span {
    display: block;
    font-size: 0.8rem;
    line-height: 1.5;
    color: var(--color-text-muted);
  }
</style>
