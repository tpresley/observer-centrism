---
import { getCollection } from 'astro:content'
import MainLayout from '../../components/layouts/MainLayout.astro'
import PageTitle from '../../components/PageTitle.astro'

const derivations = await getCollection('derivations')

const groups = {
  'Foundation': derivations.filter(d => d.data.tags.includes('foundation')),
  'Dynamics': derivations.filter(d => d.data.tags.includes('dynamics')),
  'Geometry': derivations.filter(d => d.data.tags.includes('geometry')),
  'Quantum': derivations.filter(d => d.data.tags.includes('quantum')),
  'Particles': derivations.filter(d => d.data.tags.includes('particles')),
  'Holography': derivations.filter(d => d.data.tags.includes('holography')),
  'Gauge': derivations.filter(d => d.data.tags.includes('gauge')),
  'Flavor': derivations.filter(d => d.data.tags.includes('flavor')),
  'Cosmology': derivations.filter(d => d.data.tags.includes('cosmology')),
  'Thermo Extensions': derivations.filter(d => d.data.tags.includes('thermo-ext')),
}

function statusClass(status: string) { return `status-badge status-${status}` }
const base = import.meta.env.BASE_URL.replace(/\/$/, '')
---

<MainLayout title="Derivations">
  <PageTitle title="Derivations" />
  <p>
    Rigorous derivations from the three axioms. Each derivation tracks its
    dependencies, rigor level, and what it enables.
  </p>

  <div class="legend">
    <span class="status-badge status-rigorous">rigorous</span>
    <span class="status-badge status-provisional">provisional</span>
    <span class="status-badge status-draft">draft</span>
    <span class="status-badge status-stub">stub</span>
    <span class="status-badge status-non-viable">non-viable</span>
  </div>

  {Object.entries(groups).map(([group, entries]) => (
    entries.length > 0 && (
      <>
        <h2>{group}</h2>
        <ul class="derivation-list">
          {entries.map(entry => (
            <li>
              <span class={statusClass(entry.data.status)}>{entry.data.status}</span>
              <div>
                <a href={`${base}/derivations/${entry.slug}`}>{entry.data.title}</a>
                <span class="summary">{entry.data.summary}</span>
              </div>
            </li>
          ))}
        </ul>
      </>
    )
  ))}
</MainLayout>

<style>
  .legend {
    display: flex;
    gap: 0.5rem;
    margin: 1rem 0 2rem;
  }
</style>
