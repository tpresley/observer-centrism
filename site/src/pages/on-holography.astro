      <a href={`${base}/derivations/holography/er-epr`}>ER=EPR</a> &middot;
      <a href={`${base}/derivations/foundation/observer-holographic-equivalence`}>Observer Holographic Equivalence</a> &middot;
      <a href={`${base}/derivations/foundation/observer-projected-spacetime`}>Observer-Projected Spacetime</a> &middot;
      <a href={`${base}/predictions/holographic-noise`}>Holographic Noise Prediction</a>
    </div>
  </article>
