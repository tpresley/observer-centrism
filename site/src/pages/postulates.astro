---
import MainLayout from '../components/layouts/MainLayout.astro'
import PageTitle from '../components/PageTitle.astro'
import postulatesData from '../data/structural-postulates.json'
import { getCollection } from 'astro:content'

const allDerivations = await getCollection('derivations')
const totalDerivations = allDerivations.length

const groups = {
  'Foundation': postulatesData.filter(p => p.group === 'foundation'),
  'Dynamics': postulatesData.filter(p => p.group === 'dynamics'),
  'Geometry': postulatesData.filter(p => p.group === 'geometry'),
  'Quantum': postulatesData.filter(p => p.group === 'quantum'),
  'Particles': postulatesData.filter(p => p.group === 'particles'),
  'Gauge': postulatesData.filter(p => p.group === 'gauge'),
  'Holography': postulatesData.filter(p => p.group === 'holography'),
}

const totalCount = postulatesData.length
const derivedCount = postulatesData.filter(p => p.derivedFrom).length
const activeCount = totalCount - derivedCount
const derivationsWithCount = new Set(postulatesData.map(p => p.derivation)).size
const derivationsWithoutCount = totalDerivations - derivationsWithCount
const base = import.meta.env.BASE_URL.replace(/\/$/, '')
---

<MainLayout title="Structural Postulates">
  <PageTitle title="Structural Postulates" />
  <p>
    Each derivation that requires assumptions beyond the three axioms makes them
    explicit as <strong>structural postulates</strong>. These specify the mathematical
    setting in which the derivation operates &mdash; they are not derived from the
    axioms, but they are motivated by the framework's structure. The majority of
    derivations require no additional assumptions at all.
  </p>
  {derivedCount > 0 && (
    <p class="sp-derived-note">
      <strong>{derivedCount}</strong> postulate{derivedCount > 1 ? 's' : ''} originally
      introduced as assumptions {derivedCount > 1 ? 'have' : 'has'} since been <strong>derived
      as theorems</strong> from earlier results, reducing the framework's independent assumptions.
    </p>
  )}

  <div class="sp-summary">
    <div class="sp-stat">
      <div class="sp-stat-value">{activeCount}</div>
      <div class="sp-stat-label">Active postulates</div>
    </div>
    {derivedCount > 0 && (
      <div class="sp-stat sp-stat-derived">
        <div class="sp-stat-value">{derivedCount}</div>
        <div class="sp-stat-label">Now theorems</div>
      </div>
    )}
    <div class="sp-stat">
      <div class="sp-stat-value">{derivationsWithCount}</div>
      <div class="sp-stat-label">Derivations with</div>
    </div>
    <div class="sp-stat">
      <div class="sp-stat-value">{derivationsWithoutCount}</div>
      <div class="sp-stat-label">Derivations without</div>
    </div>
  </div>

  {Object.entries(groups).map(([group, postulates]) => (
    postulates.length > 0 && (
      <>
        <h2>{group}</h2>
        <div class="sp-cards">
          {postulates.map(p => (
            <div class={`sp-card${p.derivedFrom ? ' sp-card-derived' : ''}`}>
              <div class="sp-card-header">
                <span class={`sp-badge${p.derivedFrom ? ' sp-badge-derived' : ''}`}>{p.postulateId}</span>
                <span class="sp-name">{p.shortName}</span>
                {p.derivedFrom && (
                  <span class="sp-derived-tag">Now a theorem</span>
                )}
              </div>
              <p class="sp-statement">{p.statement}</p>
              <p class="sp-justification">{p.justification}</p>
              <div class="sp-card-footer">
                <a href={`${base}/derivations/${p.derivation}`} class="sp-source">
                  {p.derivationTitle} &rarr;
                </a>
                {p.derivedFrom && (
                  <a href={`${base}/derivations/${p.derivedFrom}`} class="sp-derived-link">
                    Derived in: {p.derivedFromTitle} &rarr;
                  </a>
                )}
              </div>
            </div>
          ))}
        </div>
      </>
    )
  ))}
</MainLayout>

<style>
  .sp-summary {
    display: flex;
    gap: 1rem;
    margin: 1.5rem 0 2rem;
    flex-wrap: wrap;
  }
  .sp-stat {
    flex: 1;
    min-width: 120px;
    padding: 0.75rem 1rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    text-align: center;
  }
  .sp-stat-label {
    font-size: 0.7rem;
    text-transform: uppercase;
    color: var(--color-text-muted);
    letter-spacing: 0.04em;
  }
  .sp-stat-value {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-text);
  }
  .sp-cards {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }
  .sp-card {
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 1rem 1.25rem;
    background: var(--color-surface);
  }
  .sp-card-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
  }
  .sp-badge {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    padding: 0.15rem 0.5rem;
    border-radius: 9999px;
    background: var(--color-accent-light);
    color: var(--color-accent);
    letter-spacing: 0.03em;
    flex-shrink: 0;
  }
  .sp-name {
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--color-text);
  }
  .sp-statement {
    font-size: 0.85rem;
    line-height: 1.6;
    color: var(--color-text);
    margin-bottom: 0.5rem;
  }
  .sp-justification {
    font-size: 0.8rem;
    line-height: 1.6;
    color: var(--color-text-muted);
    font-style: italic;
    margin-bottom: 0.5rem;
  }
  .sp-source {
    font-size: 0.8rem;
    color: var(--color-accent);
    text-decoration: none;
  }
  .sp-source:hover,
  .sp-derived-link:hover {
    text-decoration: underline;
  }
  .sp-derived-note {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin: 1rem 0;
    padding: 0.75rem 1rem;
    background: color-mix(in srgb, #22c55e 8%, transparent);
    border-left: 3px solid #22c55e;
    border-radius: 4px;
  }
  .sp-stat-derived .sp-stat-value {
    color: #22c55e;
  }
  .sp-card-derived {
    border-color: #22c55e40;
    background: color-mix(in srgb, #22c55e 4%, var(--color-surface));
  }
  .sp-badge-derived {
    background: color-mix(in srgb, #22c55e 15%, transparent);
    color: #22c55e;
    text-decoration: line-through;
  }
  .sp-derived-tag {
    font-size: 0.65rem;
    font-weight: 600;
    text-transform: uppercase;
    padding: 0.1rem 0.4rem;
    border-radius: 9999px;
    background: color-mix(in srgb, #22c55e 15%, transparent);
    color: #22c55e;
    letter-spacing: 0.03em;
    flex-shrink: 0;
  }
  .sp-card-footer {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .sp-derived-link {
    font-size: 0.8rem;
    color: #22c55e;
    text-decoration: none;
  }
</style>
