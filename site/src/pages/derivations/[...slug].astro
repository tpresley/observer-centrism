---
import { getCollection } from 'astro:content'
import DerivationLayout from '../../components/layouts/DerivationLayout.astro'
import ProofStepViewer from '../../components/interactive/ProofStepViewer.jsx'

export async function getStaticPaths() {
  const entries = await getCollection('derivations')
  return entries.map(entry => ({
    params: { slug: entry.slug },
    props: { entry },
  }))
}

const { entry } = Astro.props
const { Content } = await entry.render()

// ---------------------------------------------------------------------------
// LaTeX → Unicode text conversion for ProofStepViewer
// Converts inline $...$ math to readable Unicode so the Sygnal component
// renders clean text instead of raw LaTeX.
// ---------------------------------------------------------------------------
const SUBSCRIPT_DIGITS: Record<string, string> = {
  '0': '₀', '1': '₁', '2': '₂', '3': '₃', '4': '₄',
  '5': '₅', '6': '₆', '7': '₇', '8': '₈', '9': '₉',
}
const SUPERSCRIPT_DIGITS: Record<string, string> = {
  '0': '⁰', '1': '¹', '2': '²', '3': '³', '4': '⁴',
  '5': '⁵', '6': '⁶', '7': '⁷', '8': '⁸', '9': '⁹',
  '-': '⁻', '+': '⁺',
}

function latexToText(text: string): string {
  return text.replace(/\$([^$]+)\$/g, (_, latex: string) => {
    let s = latex

    // Blackboard bold
    s = s.replace(/\\mathbb\{R\}/g, 'ℝ')
    s = s.replace(/\\mathbb\{C\}/g, 'ℂ')
    s = s.replace(/\\mathbb\{H\}/g, 'ℍ')
    s = s.replace(/\\mathbb\{O\}/g, '𝕆')
    s = s.replace(/\\mathbb\{Z\}/g, 'ℤ')
    s = s.replace(/\\mathbb\{N\}/g, 'ℕ')
    s = s.replace(/\\mathbb\{Q\}/g, 'ℚ')
    s = s.replace(/\\mathbb\{S\}/g, '𝕊')

    // Fraktur
    s = s.replace(/\\mathfrak\{so\}/g, '𝔰𝔬')
    s = s.replace(/\\mathfrak\{su\}/g, '𝔰𝔲')
    s = s.replace(/\\mathfrak\{g\}/g, '𝔤')

    // Greek lowercase
    s = s.replace(/\\alpha/g, 'α')
    s = s.replace(/\\beta/g, 'β')
    s = s.replace(/\\gamma/g, 'γ')
    s = s.replace(/\\delta/g, 'δ')
    s = s.replace(/\\varepsilon/g, 'ε')
    s = s.replace(/\\epsilon/g, 'ε')
    s = s.replace(/\\theta/g, 'θ')
    s = s.replace(/\\kappa/g, 'κ')
    s = s.replace(/\\lambda/g, 'λ')
    s = s.replace(/\\mu/g, 'μ')
    s = s.replace(/\\nu/g, 'ν')
    s = s.replace(/\\pi/g, 'π')
    s = s.replace(/\\rho/g, 'ρ')
    s = s.replace(/\\sigma/g, 'σ')
    s = s.replace(/\\tau/g, 'τ')
    s = s.replace(/\\phi/g, 'φ')
    s = s.replace(/\\psi/g, 'ψ')
    s = s.replace(/\\omega/g, 'ω')
    s = s.replace(/\\eta/g, 'η')

    // Greek uppercase
    s = s.replace(/\\Delta/g, 'Δ')
    s = s.replace(/\\Gamma/g, 'Γ')
    s = s.replace(/\\Sigma/g, 'Σ')
    s = s.replace(/\\Omega/g, 'Ω')
    s = s.replace(/\\Pi/g, 'Π')
    s = s.replace(/\\Phi/g, 'Φ')
    s = s.replace(/\\Psi/g, 'Ψ')

    // Relations and operators
    s = s.replace(/\\to(?![a-z])/g, '→')
    s = s.replace(/\\rightarrow/g, '→')
    s = s.replace(/\\leftarrow/g, '←')
    s = s.replace(/\\mapsto/g, '↦')
    s = s.replace(/\\subset/g, '⊂')
    s = s.replace(/\\supset/g, '⊃')
    s = s.replace(/\\subseteq/g, '⊆')
    s = s.replace(/\\supseteq/g, '⊇')
    s = s.replace(/\\geq/g, '≥')
    s = s.replace(/\\leq/g, '≤')
    s = s.replace(/\\neq/g, '≠')
    s = s.replace(/\\approx/g, '≈')
    s = s.replace(/\\equiv/g, '≡')
    s = s.replace(/\\sim/g, '∼')
    s = s.replace(/\\propto/g, '∝')
    s = s.replace(/\\in(?![a-z])/g, '∈')
    s = s.replace(/\\times/g, '×')
    s = s.replace(/\\cdot/g, '·')
    s = s.replace(/\\pm/g, '±')
    s = s.replace(/\\mp/g, '∓')
    s = s.replace(/\\infty/g, '∞')
    s = s.replace(/\\partial/g, '∂')
    s = s.replace(/\\nabla/g, '∇')
    s = s.replace(/\\ell/g, 'ℓ')
    s = s.replace(/\\hbar/g, 'ℏ')
    s = s.replace(/\\cong/g, '≅')
    s = s.replace(/\\simeq/g, '≃')

    // Text-mode commands (extract content)
    s = s.replace(/\\text\{([^}]*)\}/g, '$1')
    s = s.replace(/\\mathrm\{([^}]*)\}/g, '$1')
    s = s.replace(/\\operatorname\{([^}]*)\}/g, '$1')
    s = s.replace(/\\textbf\{([^}]*)\}/g, '$1')
    s = s.replace(/\\mathcal\{([^}]*)\}/g, '$1')
    s = s.replace(/\\mathbf\{([^}]*)\}/g, '$1')

    // Superscripts: ^{...} and ^X
    s = s.replace(/\^\{([^}]*)\}/g, (_, sup: string) => {
      return sup.split('').map(c => SUPERSCRIPT_DIGITS[c] || c).join('')
    })
    s = s.replace(/\^([0-9\-+])/g, (_, c: string) => SUPERSCRIPT_DIGITS[c] || c)

    // Subscripts: _{...} and _X
    s = s.replace(/_\{([^}]*)\}/g, (_, sub: string) => {
      // If all digits, use Unicode subscripts
      if (/^\d+$/.test(sub)) return sub.split('').map(c => SUBSCRIPT_DIGITS[c]).join('')
      // Otherwise keep as regular text
      return sub
    })
    s = s.replace(/_([0-9])/g, (_, d: string) => SUBSCRIPT_DIGITS[d])

    // Spacing commands → single space or nothing
    s = s.replace(/\\[,;:!]\s?/g, '')
    s = s.replace(/\\quad/g, ' ')
    s = s.replace(/\\qquad/g, ' ')
    s = s.replace(/\\enspace/g, ' ')

    // Strip any remaining backslash commands (e.g., \overline, \hat)
    s = s.replace(/\\[a-zA-Z]+/g, '')

    // Clean up braces and whitespace
    s = s.replace(/[{}]/g, '')
    s = s.replace(/\s+/g, ' ')
    s = s.trim()

    return s
  })
}

// Extract proof steps from the markdown body
// Look for h3 headings that follow the "Step N: Title" pattern
const body = entry.body || ''
const hasOverview = /^##\s+Overview\s*$/m.test(body)
const stepRegex = /^###\s+Step\s+\d+[:\s]+(.+)$/gm
const stepMatches: { title: string; index: number; length: number }[] = []

let match
while ((match = stepRegex.exec(body)) !== null) {
  stepMatches.push({
    title: match[1].trim(),
    index: match.index,
    length: match[0].length,
  })
}

// Find section boundaries (next ### heading or ## heading or end of file)
const sectionBoundaryRegex = /^##[#]?\s+/gm
const sectionStarts: number[] = []
let bMatch
while ((bMatch = sectionBoundaryRegex.exec(body)) !== null) {
  sectionStarts.push(bMatch.index)
}

const steps: { title: string; anchor: string; summary: string; keyResult: string }[] = []

for (let i = 0; i < stepMatches.length; i++) {
  const sm = stepMatches[i]
  const rawTitle = sm.title
  const title = latexToText(rawTitle)

  // Create an anchor slug from the raw heading text (must match rehype-slug output)
  const fullHeading = `Step ${i + 1}: ${rawTitle}`
  const anchor = '#' + fullHeading
    .toLowerCase()
    .replace(/[^\w\s-]/g, '')
    .replace(/\s+/g, '-')
    .replace(/-+/g, '-')
    .replace(/^-|-$/g, '')

  // Bound the search to just this step's section (until next heading)
  const stepStart = sm.index + sm.length
  const nextBoundary = sectionStarts.find(s => s > stepStart)
  const sectionText = nextBoundary
    ? body.slice(stepStart, nextBoundary)
    : body.slice(stepStart)

  // Extract key result: first **Theorem/Proposition/Corollary/Definition N.N**
  const resultMatch = sectionText.match(/\*\*(Theorem|Proposition|Corollary|Definition)\s+[\d.]+[^*]*\*\*/)
  const keyResult = resultMatch ? latexToText(resultMatch[0].replace(/\*\*/g, '')) : ''

  // Extract summary: first italicized statement after bold marker, bounded to this section
  let summary = ''
  const summaryMatch = sectionText.match(/\*\*[^*]+\*\*[.\s]*\*([^*]+)\*/)
  if (summaryMatch && summaryMatch[1]) {
    summary = latexToText(summaryMatch[1].trim())
      .replace(/\s+/g, ' ')
    if (summary.length > 100) {
      summary = summary.slice(0, 97) + '...'
    }
  }

  steps.push({ title, anchor, keyResult, summary })
}
---

<DerivationLayout
  title={entry.data.title}
  status={entry.data.status}
  dependsOn={entry.data.dependsOn}
  enablesDerivation={entry.data.enablesDerivation}

  leanProofs={entry.data.leanProofs}
  hasOverview={hasOverview}
>
  {steps.length >= 2 && (
    <ProofStepViewer client:load steps={steps} />
  )}
  <Content />
</DerivationLayout>
