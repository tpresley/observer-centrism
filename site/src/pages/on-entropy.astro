    font-size: 1.35rem;
    border-top: 1px solid var(--color-border);
    padding-top: 1.5rem;
  }

  .entropy-article h2:first-of-type {
    border-top: none;
    padding-top: 0;
  }

  .entropy-article p {
    margin-bottom: 1rem;
    line-height: 1.85;
  }

  .entropy-article ul {
    margin-bottom: 1.25rem;
    padding-left: 1.5rem;
  }

  .entropy-article li {
    margin-bottom: 0.75rem;
    line-height: 1.75;
  }

  .lead {
    font-size: 1.05rem;
    line-height: 1.8;
    color: var(--color-text-muted);
    margin-bottom: 2rem;
  }

  .entropy-links {
    margin-top: 2.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-border);
    text-align: center;
    font-size: 0.9rem;
  }

  .entropy-links a {
    color: var(--color-accent);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: border-color 0.15s;
  }

  .entropy-links a:hover {
