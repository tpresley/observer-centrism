---
import { getCollection } from 'astro:content'
import MainLayout from '../../components/layouts/MainLayout.astro'
import PageTitle from '../../components/PageTitle.astro'

const derivations = await getCollection('derivations')
const bySlug = new Map(derivations.map(d => [d.slug, d]))

// Explicit ordered slug lists — each derivation appears exactly once,
// in approximate dependency order. Matches Sidebar.astro.
const GROUP_ORDER: Record<string, string[]> = {
  'Axioms': [
    'axioms/00-from-observation-to-axioms',
    'axioms/coherence-conservation',
    'axioms/observer-definition',
    'axioms/loop-closure',
  ],
  'Foundation': [
    'minimal-observer/structure',
    'minimal-observer/multiplicity',
    'minimal-observer/coherence-dual-pairs',
    'axioms/coherence-operational',
    'foundation/coherence-lagrangian',
    'foundation/aperiodic-order',
    'foundation/continuous-discrete-duality',
    'foundation/knot-theoretic-bootstrap',
    'foundation/observer-projected-spacetime',
    'foundation/observer-holographic-equivalence',
    'foundation/minimum-bootstrap-closure',
  ],
  'Dynamics': [
    'interactions/three-types',
    'interactions/relational-invariants',
    'interactions/bootstrap',
    'interactions/bootstrap-division-algebras',
    'thermodynamics/time',
    'thermodynamics/entropy',
    'thermodynamics/action-planck',
  ],
  'Geometry': [
    'dimensions/three-dimensions',
    'spacetime/speed-of-light',
    'spacetime/lorentz-invariance',
    'spacetime/gravity',
    'spacetime/einstein-equations',
    'spacetime/singularity-resolution',
    'spacetime/gravitational-constant',
  ],
  'Quantum': [
    'quantum/born-rule',
    'quantum/preferred-basis',
    'quantum/measurement',
    'quantum/entanglement',
    'quantum/teleportation',
    'quantum/observer-relative-objectivity',
    'quantum/sheaf-section-uniqueness',
  ],
  'Particles': [
    'particles/spin-statistics',
    'particles/pauli-exclusion',
    'particles/three-generations',
    'particles/mass-hierarchy',
    'particles/neutrino-masses',
    'particles/cpt-theorem',
    'particles/supersymmetry-impossibility',
  ],
  'Holography': [
    'holography/area-scaling',
    'holography/causal-set-statistics',
    'holography/black-hole-entropy',
    'holography/hawking-radiation',
    'holography/information-paradox',
    'holography/er-epr',
    'holography/scrambling',
    'holography/horizon-gauge-shell',
  ],
  'Gauge': [
    'gauge/electromagnetism',
    'gauge/weak-interaction',
    'gauge/electroweak-breaking',
    'gauge/chirality-selection',
    'gauge/color-force',
    'gauge/standard-model-group',
    'gauge/confinement',
    'gauge/strong-cp',
    'gauge/anomaly-cancellation',
    'gauge/chiral-symmetry-breaking',
    'gauge/weinberg-angle',
    'gauge/proton-stability',
  ],
  'Flavor': [
    'flavor/mixing-angles',
  ],
  'Cosmology': [
    'cosmology/geometric-inflation',
    'cosmology/cosmological-constant',
    'cosmology/baryogenesis',
    'cosmology/leptogenesis',
    'cosmology/coupling-constants',
    'cosmology/observer-loop-viability',
    'cosmology/dark-energy-equation-of-state',
    'cosmology/geometric-substrate',
    'cosmology/cyclic-cosmology',
    'cosmology/cosmological-arrow',
  ],
  'Thermo Extensions': [
    'thermodynamics-ext/distinguishability-conservation',
    'thermodynamics-ext/first-law',
    'thermodynamics-ext/fisher-metric',
    'thermodynamics-ext/renormalization',
    'thermodynamics-ext/memory-persistence-tradeoff',
    'thermodynamics-ext/non-ergodicity',
    'thermodynamics-ext/biological-non-ergodicity',
  ],
}

const groups = Object.fromEntries(
  Object.entries(GROUP_ORDER).map(([group, slugs]) => [
    group,
    slugs.map(s => bySlug.get(s)).filter(Boolean)
  ])
)

function statusClass(status: string) { return `status-badge status-${status}` }
const base = import.meta.env.BASE_URL.replace(/\/$/, '')
---

<MainLayout title="Derivations">
  <PageTitle title="Derivations" />
  <p>
    Rigorous derivations from the three axioms. Each derivation tracks its
    dependencies, rigor level, and what it enables.
  </p>

  <div class="legend">
    <span class="status-badge status-derived">derived</span>
    <span class="status-badge status-provisional">provisional</span>
    <span class="status-badge status-draft">draft</span>
    <span class="status-badge status-stub">stub</span>
    <span class="status-badge status-non-viable">non-viable</span>
  </div>

  {Object.entries(groups).map(([group, entries]) => (
    entries.length > 0 && (
      <>
        <h2>{group}</h2>
        <ul class="derivation-list">
          {entries.map(entry => (
            <li>
              <span class={statusClass(entry.data.status)}>{entry.data.status}</span>
              <div>
                <a href={`${base}/derivations/${entry.slug}`}>{entry.data.title}</a>
                <span class="summary">{entry.data.summary}</span>
              </div>
            </li>
          ))}
        </ul>
      </>
    )
  ))}
</MainLayout>

<style>
  .legend {
    display: flex;
    gap: 0.5rem;
    margin: 1rem 0 2rem;
  }
</style>
