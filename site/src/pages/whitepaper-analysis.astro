    viabilityNotes: "The current framework's Einstein equations derivation arrives at exactly the standard equations (no corrections). Any deviation would contradict the Lovelock uniqueness argument used in the derivation. For this prediction to be viable, the framework would need a mechanism producing sub-leading corrections — potentially from the discrete relational invariant network at Planck scales — but this is beyond current development."
  },
  {
    id: 34,
    name: "Constraint-pressure waves in BECs",
    wpSection: "Predictions (§7)",
    description: "Coherence-acoustic dispersion ω² = c_σ²k² + ℏ²k⁴/4m² producing dual linear + quartic dispersion branches in Bose-Einstein condensates or nonlinear optical media.",
    coverage: 'not-covered',
    coverageNotes: "The current framework does not make predictions about BEC dispersion relations.",
    viability: 'low',
    viabilityNotes: "The Bogoliubov dispersion relation for BECs already has this form (ω² = c_s²k² + (ℏk²/2m)²) from standard quantum mechanics. The prediction in the whitepaper appears to rediscover a known result rather than predict a new effect. Within the current framework, BEC behavior would follow from the standard quantum mechanics that the framework derives, without additional prediction."
  },
  {
    id: 35,
    name: "Collective coherence in biological/neural networks",
    wpSection: "Predictions (§7)",
    description: "Frictionless information flow in phase-locked networks (biological, neural, computational) once mutual coherence saturates the invariant. Observable as anomalous synchronization efficiency.",
    coverage: 'not-covered',
    coverageNotes: "The current framework restricts its scope to fundamental physics and does not make predictions about biological systems.",
    viability: 'low',
    viabilityNotes: "While the bootstrap mechanism describes universal hierarchical structure, applying it to biological synchronization requires bridging multiple levels of description. The claim of 'frictionless information flow' in neural networks at coherence saturation is speculative and would require showing that biological systems can reach the relevant coherence threshold — which involves thermodynamics and noise at scales far above the Planck scale."
  }
]

const coverageLabel = (c: Coverage) => {
  switch(c) {
    case 'covered': return 'Covered'
    case 'partial': return 'Partial'
    case 'not-covered': return 'Not covered'
  }
}

const coverageClass = (c: Coverage) => `wa-cov-${c}`

const viabilityLabel = (v: Viability) => {
  switch(v) {
    case 'high': return 'High'
    case 'medium': return 'Medium'
    case 'low': return 'Low'
    case 'not-viable': return 'Not viable'
  }
}

const viabilityClass = (v: Viability) => `wa-via-${v}`

// Summary stats
const covered = ideas.filter(i => i.coverage === 'covered').length
const partial = ideas.filter(i => i.coverage === 'partial').length
const notCovered = ideas.filter(i => i.coverage === 'not-covered').length
const highViability = ideas.filter(i => i.viability === 'high').length
const medViability = ideas.filter(i => i.viability === 'medium').length
---

<MainLayout title="Whitepaper Analysis">
  <PageTitle title="Prior Whitepaper: Idea Analysis" />
  <p>
    An earlier version of the Observer-Centrism framework (dated October 2025) used a
    different mathematical foundation &mdash; information geometry, KL divergence, and
    a specific variational action &mdash; to pursue many of the same goals. That version
    was less rigorous and likely contains logic and mathematical errors, but some of its
    ideas may be worth pursuing within the current, more rigorous framework.
  </p>
  <p>
    This page catalogs every distinct idea from that whitepaper, assesses whether it is
    already covered by the current framework, and evaluates the viability of absorbing
    ideas that are not yet covered. Viability is judged by whether an idea is
    <em>plausibly derivable</em> from the current framework's axioms and derivation chain,
    regardless of the logic used in the whitepaper.
  </p>

  <div class="wa-summary">
    <div class="wa-stat">
      <div class="wa-stat-value">{ideas.length}</div>
      <div class="wa-stat-label">Ideas cataloged</div>
    </div>
    <div class="wa-stat">
      <div class="wa-stat-value">{covered}</div>
      <div class="wa-stat-label">Already covered</div>
    </div>
    <div class="wa-stat">
      <div class="wa-stat-value">{partial}</div>
      <div class="wa-stat-label">Partially covered</div>
    </div>
    <div class="wa-stat">
      <div class="wa-stat-value">{notCovered}</div>
      <div class="wa-stat-label">Not yet covered</div>
    </div>
    <div class="wa-stat">
      <div class="wa-stat-value">{highViability + medViability}</div>
      <div class="wa-stat-label">High/medium viability</div>
    </div>
  </div>

  {ideas.map(idea => (
    <div class="wa-card" id={`idea-${idea.id}`}>
      <div class="wa-card-header">
        <span class="wa-id">{idea.id}</span>
        <h3 class="wa-name">{idea.name}</h3>
        <div class="wa-badges">
          <span class={`wa-badge ${coverageClass(idea.coverage)}`}>{coverageLabel(idea.coverage)}</span>
          <span class={`wa-badge ${viabilityClass(idea.viability)}`}>{viabilityLabel(idea.viability)}</span>
        </div>
      </div>
      <div class="wa-section-ref">{idea.wpSection}</div>
      <p class="wa-description">{idea.description}</p>
      <div class="wa-assessment">
        <div class="wa-assessment-block">
          <h4>Coverage in current framework</h4>
          <p>{idea.coverageNotes}</p>
        </div>
        <div class="wa-assessment-block">
          <h4>Viability for absorption</h4>
          <p>{idea.viabilityNotes}</p>
        </div>
      </div>
    </div>
  ))}
</MainLayout>

<style>
  .wa-summary {
    display: flex;
    gap: 0.75rem;
    margin: 1.5rem 0 2rem;
    flex-wrap: wrap;
  }
  .wa-stat {
