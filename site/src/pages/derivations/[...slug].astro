---
import { getCollection } from 'astro:content'
import DerivationLayout from '../../components/layouts/DerivationLayout.astro'

export async function getStaticPaths() {
  const entries = await getCollection('derivations')
  return entries.map(entry => ({
    params: { slug: entry.slug },
    props: { entry },
  }))
}

const { entry } = Astro.props
const { Content } = await entry.render()
---

<DerivationLayout
  title={entry.data.title}
  status={entry.data.status}
  dependsOn={entry.data.dependsOn}
  enablesDerivation={entry.data.enablesDerivation}
  sourceSection={entry.data.sourceSection}
>
  <Content />
</DerivationLayout>
