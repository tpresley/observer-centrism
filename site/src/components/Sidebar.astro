---
import { getCollection } from 'astro:content'

interface Props {
  currentPath: string
}

const { currentPath } = Astro.props
const base = import.meta.env.BASE_URL.replace(/\/$/, '')

const derivationEntries = await getCollection('derivations')
const predictionEntries = await getCollection('predictions')
const guideEntries = await getCollection('guide')
const domainEntries = await getCollection('domains')
const gaEntries = await getCollection('geometric-algebra')

const sortedGuide = guideEntries.sort((a, b) => a.data.order - b.data.order)
const sortedDomains = domainEntries.sort((a, b) => a.data.order - b.data.order)

const domainIcons: Record<string, string> = {
  'quantum-foundations': '\u269B',
  'cosmology': '\u2604',
  'particle-physics': '\u2699',
  'holography': '\u25C9',
}

/** Strip base prefix from path for comparison */
const pathWithoutBase = currentPath.startsWith(base) ? (currentPath.slice(base.length) || '/') : currentPath

/** Normalize trailing slashes and compare */
function isActive(href: string): boolean {
  const norm = (s: string) => s.replace(/\/+$/, '') || '/'
  return norm(pathWithoutBase) === norm(href)
}

const isGAPage = pathWithoutBase.startsWith('/geometric-algebra/')

const gaTopics = gaEntries.filter(e => e.slug !== 'overview')
const GA_GROUP_ORDER = ['STA Core', 'Rotors & Topology', 'Algebra Bridge', 'Applications']
const STA_CORE = new Set(['lorentz-invariance', 'cpt-theorem', 'electromagnetism'])
const ROTORS_TOPOLOGY = new Set(['spin-statistics', 'weak-interaction', 'chirality-selection'])
const ALGEBRA_BRIDGE = new Set(['division-algebras'])
const APPLICATIONS = new Set(['entanglement', 'er-epr', 'gravity', 'einstein-equations'])

function gaGroup(slug: string): string {
  if (STA_CORE.has(slug)) return 'STA Core'
  if (ROTORS_TOPOLOGY.has(slug)) return 'Rotors & Topology'
  if (ALGEBRA_BRIDGE.has(slug)) return 'Algebra Bridge'
  if (APPLICATIONS.has(slug)) return 'Applications'
  return 'Other'
}

const gaGroups = new Map<string, typeof gaTopics>()
for (const g of GA_GROUP_ORDER) {
  const entries = gaTopics.filter(e => gaGroup(e.slug) === g)
  if (entries.length > 0) gaGroups.set(g, entries)
}

// Explicit ordered slug lists: each derivation appears exactly once,
// in approximate dependency order within each group.
const DERIVATION_GROUPS: Record<string, string[]> = {
  'Axioms': [
    'axioms/coherence-conservation',
    'axioms/observer-definition',
    'axioms/loop-closure',
  ],
  'Foundation': [
    'minimal-observer/structure',
    'minimal-observer/multiplicity',
    'minimal-observer/coherence-dual-pairs',
    'axioms/coherence-operational',
    'foundation/coherence-lagrangian',
    'foundation/aperiodic-order',
    'foundation/continuous-discrete-duality',
  ],
  'Dynamics': [
    'interactions/three-types',
    'interactions/relational-invariants',
    'interactions/bootstrap',
    'interactions/bootstrap-division-algebras',
    'thermodynamics/time',
    'thermodynamics/entropy',
    'thermodynamics/action-planck',
  ],
  'Geometry': [
    'dimensions/three-dimensions',
    'spacetime/speed-of-light',
    'spacetime/lorentz-invariance',
    'spacetime/gravity',
    'spacetime/einstein-equations',
    'spacetime/singularity-resolution',
    'spacetime/gravitational-constant',
  ],
  'Quantum': [
    'quantum/born-rule',
    'quantum/preferred-basis',
    'quantum/measurement',
    'quantum/entanglement',
    'quantum/teleportation',
    'quantum/observer-relative-objectivity',
    'quantum/sheaf-section-uniqueness',
  ],
  'Particles': [
    'particles/spin-statistics',
    'particles/pauli-exclusion',
    'particles/three-generations',
    'particles/mass-hierarchy',
    'particles/neutrino-masses',
    'particles/cpt-theorem',
    'particles/supersymmetry-impossibility',
  ],
  'Holography': [
    'holography/area-scaling',
    'holography/causal-set-statistics',
    'holography/black-hole-entropy',
    'holography/hawking-radiation',
    'holography/information-paradox',
    'holography/er-epr',
    'holography/scrambling',
  ],
  'Gauge': [
    'gauge/electromagnetism',
    'gauge/weak-interaction',
    'gauge/electroweak-breaking',
    'gauge/chirality-selection',
    'gauge/color-force',
    'gauge/standard-model-group',
    'gauge/confinement',
    'gauge/strong-cp',
    'gauge/anomaly-cancellation',
    'gauge/chiral-symmetry-breaking',
    'gauge/weinberg-angle',
    'gauge/proton-stability',
  ],
  'Flavor': [
    'flavor/mixing-angles',
  ],
  'Cosmology': [
    'cosmology/geometric-inflation',
    'cosmology/cosmological-constant',
    'cosmology/baryogenesis',
    'cosmology/leptogenesis',
    'cosmology/coupling-constants',
    'cosmology/observer-loop-viability',
    'cosmology/dark-energy-equation-of-state',
    'cosmology/geometric-substrate',
    'cosmology/cosmological-arrow',
  ],
  'Thermo Extensions': [
    'thermodynamics-ext/distinguishability-conservation',
    'thermodynamics-ext/first-law',
    'thermodynamics-ext/fisher-metric',
    'thermodynamics-ext/renormalization',
    'thermodynamics-ext/non-ergodicity',
    'thermodynamics-ext/biological-non-ergodicity',
  ],
}

// Build ordered entries by looking up each slug in the collection
const derivationsBySlug = new Map(derivationEntries.map(d => [d.slug, d]))
const derivationGroups = Object.fromEntries(
  Object.entries(DERIVATION_GROUPS).map(([group, slugs]) => [
    group,
    slugs.map(s => derivationsBySlug.get(s)).filter(Boolean)
  ])
)

function statusIcon(status: string) {
  switch(status) {
    case 'rigorous': return '●'
    case 'provisional': return '◐'
    case 'draft': return '○'
    case 'stub': return '·'
    case 'non-viable': return '✗'
    default: return '·'
  }
}

function statusColor(status: string) {
  switch(status) {
    case 'rigorous': return 'var(--color-rigorous)'
    case 'provisional': return 'var(--color-provisional)'
    case 'draft': return 'var(--color-draft)'
    case 'stub': return 'var(--color-stub)'
    case 'non-viable': return 'var(--color-non-viable)'
    default: return 'var(--color-stub)'
  }
}
---

<nav class="sidebar" aria-label="Main navigation">
  <a href={`${base}/`} class="site-brand" aria-label="Home">
    <img src={`${base}/favicon.svg`} alt="" class="site-logo" width="36" height="36" />
    <div>
      <div class="site-title">Observer-Centrism</div>
      <div class="site-subtitle">Physics from Three Axioms</div>
    </div>
  </a>

  <a href={`${base}/`} aria-current={isActive('/') ? 'page' : undefined}>
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
    Home
  </a>
  <a href={`${base}/central-thesis`} aria-current={isActive('/central-thesis') ? 'page' : undefined}>
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="4"/><line x1="4.93" y1="4.93" x2="9.17" y2="9.17"/><line x1="14.83" y1="14.83" x2="19.07" y2="19.07"/><line x1="14.83" y1="9.17" x2="19.07" y2="4.93"/><line x1="4.93" y1="19.07" x2="9.17" y2="14.83"/></svg>
    The Central Thesis
  </a>
  <a href={`${base}/note-to-researchers`} aria-current={isActive('/note-to-researchers') ? 'page' : undefined}>
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
    Note to Researchers
  </a>
  <a href={`${base}/mysteries`} aria-current={isActive('/mysteries') ? 'page' : undefined}>
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
    Mysteries of Physics
  </a>
  <a href={`${base}/science-fiction`} aria-current={isActive('/science-fiction') ? 'page' : undefined}>
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
    Science Fiction &amp; Physics
  </a>
  <a href={`${base}/map`} aria-current={isActive('/map') ? 'page' : undefined}>
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
    Derivation Map
  </a>
  <a href={`${base}/postulates`} aria-current={isActive('/postulates') ? 'page' : undefined}>
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="6" y1="3" x2="6" y2="21"/><line x1="12" y1="3" x2="12" y2="21"/><line x1="18" y1="3" x2="18" y2="21"/><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
    Structural Postulates
  </a>
  <a href={`${base}/parameters`} aria-current={isActive('/parameters') ? 'page' : undefined}>
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M12 1v4M12 19v4M4.22 4.22l2.83 2.83M16.95 16.95l2.83 2.83M1 12h4M19 12h4M4.22 19.78l2.83-2.83M16.95 7.05l2.83-2.83"/></svg>
    Parameters
  </a>
  <a href={`${base}/open-gaps`} aria-current={isActive('/open-gaps') ? 'page' : undefined}>
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
    Open Gaps
  </a>
  <a href={`${base}/theorems`} aria-current={isActive('/theorems') ? 'page' : undefined}>
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
    Theorems
  </a>
  <a href={`${base}/predictions/`} aria-current={isActive('/predictions/') ? 'page' : undefined}>
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
    Predictions
  </a>
  <a href={`${base}/references`} aria-current={isActive('/references') ? 'page' : undefined}>
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
    References
  </a>
  <a href={`${base}/search`} aria-current={isActive('/search') ? 'page' : undefined}>
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
    Search
  </a>
  <a href={`${base}/sitemap`} aria-current={isActive('/sitemap') ? 'page' : undefined}>
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>
    Site Map
  </a>

  <h2>Guide</h2>
  <a href={`${base}/guide/`} aria-current={isActive('/guide/') ? 'page' : undefined}>Overview</a>
  {sortedGuide.map(entry => (
    <a href={`${base}/guide/${entry.slug}`} aria-current={isActive(`/guide/${entry.slug}`) ? 'page' : undefined}>
      {entry.data.order}. {entry.data.title}
    </a>
  ))}

  <h2>Domains</h2>
  <a href={`${base}/domains/`} aria-current={isActive('/domains/') ? 'page' : undefined}>Overview</a>
  {sortedDomains.map(entry => (
    <a href={`${base}/domains/${entry.slug}`} aria-current={isActive(`/domains/${entry.slug}`) ? 'page' : undefined}>
      <span class="domain-icon">{domainIcons[entry.slug] || '\u25CB'}</span> {entry.data.title}
    </a>
  ))}

  <h2>Derivations</h2>
  <a href={`${base}/derivations/`} aria-current={isActive('/derivations/') ? 'page' : undefined}>Index</a>
  {Object.entries(derivationGroups).map(([group, entries]) => (
    entries.length > 0 && (
      <>
        <div class="sidebar-group-label">{group}</div>
        {entries.map(entry => (
          <a href={`${base}/derivations/${entry.slug}`} aria-current={isActive(`/derivations/${entry.slug}`) ? 'page' : undefined}>
            <span style={`color: ${statusColor(entry.data.status)}`}>{statusIcon(entry.data.status)}</span>
            {' '}{entry.data.title}
          </a>
        ))}
      </>
    )
  ))}

  <h2>Predictions</h2>
  {predictionEntries.map(entry => (
    <a href={`${base}/predictions/${entry.slug}`} aria-current={isActive(`/predictions/${entry.slug}`) ? 'page' : undefined}>{entry.data.title}</a>
  ))}

  <details class="sidebar-details" open={isGAPage || undefined}>
    <summary><h2>GA Exploration</h2></summary>
    <a href={`${base}/geometric-algebra/`} aria-current={isActive('/geometric-algebra/') ? 'page' : undefined}>Overview</a>
    {[...gaGroups.entries()].map(([groupName, entries]) => (
      <>
        <div class="sidebar-group-label">{groupName}</div>
        {entries.map(entry => (
          <a href={`${base}/geometric-algebra/${entry.slug}`} aria-current={isActive(`/geometric-algebra/${entry.slug}`) ? 'page' : undefined}>
            <span style={`color: ${statusColor(entry.data.status)}`}>{statusIcon(entry.data.status)}</span>
            {' '}{entry.data.title}
          </a>
        ))}
      </>
    ))}
  </details>

  <div class="sidebar-footer">
    <a href={`${base}/contribute`} aria-current={isActive('/contribute') ? 'page' : undefined}>
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="16"/><line x1="8" y1="12" x2="16" y2="12"/></svg>
      How to Contribute
    </a>
  </div>

</nav>

<script>
  // Scroll the active sidebar link into view on page load
  const active = document.querySelector('nav.sidebar a[aria-current="page"]');
  if (active) {
    // Use requestAnimationFrame to ensure layout is complete
    requestAnimationFrame(() => {
      active.scrollIntoView({ block: 'center', behavior: 'instant' });
    });
  }
</script>

<style>
  nav > a > svg {
    vertical-align: -2px;
    margin-right: 6px;
    opacity: 0.55;
  }
  .sidebar-group-label {
    font-size: 0.7rem;
    text-transform: uppercase;
    color: var(--color-text-muted);
    padding: 0.5rem 0.5rem 0.15rem;
    letter-spacing: 0.04em;
  }
  .sidebar-details {
    margin: 0;
  }
  .sidebar-details summary {
    cursor: pointer;
    list-style: none;
  }
  .sidebar-details summary::-webkit-details-marker {
    display: none;
  }
  .sidebar-details summary h2 {
    display: inline;
  }
  .sidebar-details summary h2::after {
    content: ' \25B6';
    font-size: 0.5rem;
    vertical-align: middle;
    color: var(--color-text-muted);
  }
  .sidebar-details[open] summary h2::after {
    content: ' \25BC';
  }
  .domain-icon {
    display: inline-block;
    width: 1.1em;
    text-align: center;
    font-size: 0.85em;
  }
  .sidebar-footer {
    margin-top: 1.5rem;
    padding-top: 1rem;
    border-top: 1px solid var(--color-border);
  }
  .sidebar-footer a > svg {
    vertical-align: -2px;
    margin-right: 6px;
    opacity: 0.55;
  }
</style>
