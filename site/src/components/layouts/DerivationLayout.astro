---
import MainLayout from './MainLayout.astro'
import graphData from '../../data/dependency-graph.json'

interface LeanProof {
  module: string
  proposition: string
  theorems: string[]
}

interface Props {
  title: string
  status?: string
  dependsOn?: string[]
  enablesDerivation?: string[]

  leanProofs?: LeanProof[]
  hasOverview?: boolean
}

const { title, status, dependsOn = [], enablesDerivation = [], leanProofs = [], hasOverview = false } = Astro.props
const base = import.meta.env.BASE_URL.replace(/\/$/, '')

const statusClass = status ? `status-${status}` : ''

const titleMap: Record<string, string> = {}
for (const node of graphData.nodes) {
  titleMap[node.id] = node.title
}

function getTitle(id: string): string {
  return titleMap[id] || id
}

function slugifyProp(prop: string): string {
  return prop.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/-+$/, '')
}

const totalTheorems = leanProofs.reduce((sum, p) => sum + p.theorems.length, 0)
---

<MainLayout title={title}>
  <article>
    <header>
      <h1>{title}</h1>
      {status && <span class={`status-badge ${statusClass}`}>{status}</span>}
      {leanProofs.length > 0 && (
        <span class="lean-badge">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="20 6 9 17 4 12"></polyline>
          </svg>
          Lean 4 verified
        </span>
      )}
    </header>

    {dependsOn.length > 0 && (
      <div class="depends-on">
        <h4>Depends On</h4>
        <ul>
          {dependsOn.map(dep => (
            <li><a href={`${base}/derivations/${dep}`}>{getTitle(dep)}</a></li>
          ))}
        </ul>
      </div>
    )}

    {leanProofs.length > 0 && (
      <details class="lean-proofs-section">
        <summary>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="20 6 9 17 4 12"></polyline>
          </svg>
          Lean 4 Verified &mdash; {leanProofs.length} {leanProofs.length === 1 ? 'result' : 'results'}, {totalTheorems} Lean {totalTheorems === 1 ? 'theorem' : 'theorems'}
        </summary>
        <p class="lean-explanation">
          The results below have been independently checked in
          <a href="https://lean-lang.org" target="_blank" rel="noopener">Lean 4</a>,
          a proof assistant that mechanically verifies every logical step.
          Click a result name to jump to it in the derivation.
        </p>
        <div class="lean-proofs-list">
          {leanProofs.map(proof => (
            <div class="lean-proof-item">
              <div class="lean-proof-header">
                <a href={`#lean-${slugifyProp(proof.proposition)}`} class="lean-prop-link">
                  {proof.proposition}
                </a>
                <span class="lean-theorem-count">
                  {proof.theorems.length} Lean {proof.theorems.length === 1 ? 'theorem' : 'theorems'}
                </span>
              </div>
              <span class="lean-module">{proof.module}</span>
              <ul class="lean-theorems">
                {proof.theorems.map(t => (
                  <li><code>{t}</code></li>
                ))}
              </ul>
              <a
                href={`https://github.com/tpresley/observer-centrism/blob/main/lean/${proof.module.replace(/\./g, '/')}.lean`}
                class="lean-source-link"
                target="_blank"
                rel="noopener"
              >
                View Lean source &rarr;
              </a>
            </div>
          ))}
        </div>
      </details>
    )}

    <slot />

    {enablesDerivation.length > 0 && (
      <div class="depends-on" style="margin-top: 2rem;">
        <h4>Enables</h4>
        <ul>
          {enablesDerivation.map(d => (
            <li><a href={`${base}/derivations/${d}`}>{getTitle(d)}</a></li>
          ))}
        </ul>
      </div>
    )}
  </article>
</MainLayout>

{leanProofs.length > 0 && (
  <script define:vars={{ propositions: leanProofs.map(p => p.proposition) }}>
    document.addEventListener('DOMContentLoaded', () => {
      const article = document.querySelector('article')
      if (!article) return

      const strongs = article.querySelectorAll('strong')
      const checkSvg = '<svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>'
      const tagged = new Set()

      for (const el of strongs) {
        const text = el.textContent || ''
        for (const prop of propositions) {
          if (text.startsWith(prop) && !tagged.has(prop)) {
            tagged.add(prop)

            // Add id for anchor linking from the panel
            const slug = prop.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/-+$/, '')
            el.id = 'lean-' + slug

            // Create and inject inline badge
            const badge = document.createElement('span')
            badge.className = 'lean-inline-badge'
            badge.innerHTML = checkSvg + ' verified'
            badge.title = prop + ' has been formally verified in Lean 4'
            el.parentNode.insertBefore(badge, el.nextSibling)
            break
          }
        }
      }
    })
  </script>
)}

{hasOverview && (
  <script is:inline>
    (function initOverviewTabs() {
      const article = document.querySelector('article')
      if (!article) {
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', initOverviewTabs)
        }
        return
      }

      // Find the overview <h2> by its id (generated by rehype-slug)
      const overviewH2 = article.querySelector('h2#overview')
      if (!overviewH2) return

      // Collect all direct children of <article>
      const children = Array.from(article.children)

      // Identify slot content boundaries.
      // Slot content = everything after the leading structural block
      // (header, depends-on, lean-proofs, plus Astro infrastructure
      // scripts/styles) and before the trailing Enables .depends-on div.
      let slotStart = 0
      for (let i = 0; i < children.length; i++) {
        const el = children[i]
        const isStructural = (
          el.tagName === 'HEADER' ||
          el.classList.contains('depends-on') ||
          el.classList.contains('lean-proofs-section') ||
          el.tagName === 'STYLE' ||
          el.tagName === 'SCRIPT'
        )
        if (isStructural) {
          slotStart = i + 1
        } else {
          break
        }
      }

      // Find trailing Enables div (last .depends-on in the article)
      let slotEnd = children.length
      for (let i = children.length - 1; i >= slotStart; i--) {
        if (children[i].classList.contains('depends-on')) {
          slotEnd = i
          break
        }
      }

      const slotElements = children.slice(slotStart, slotEnd)
      if (slotElements.length === 0) return

      // Partition into overview and derivation content.
      // Overview = from <h2>Overview</h2> until the next <h2>.
      // Derivation = everything else (ProofStepViewer + all other sections).
      const overviewNodes = []
      const derivationNodes = []
      let inOverview = false

      for (const el of slotElements) {
        if (el === overviewH2) {
          inOverview = true
          overviewNodes.push(el)
          continue
        }
        if (inOverview && el.tagName === 'H2') {
          inOverview = false
          derivationNodes.push(el)
          continue
        }
        if (inOverview) {
          overviewNodes.push(el)
        } else {
          derivationNodes.push(el)
        }
      }

      if (overviewNodes.length === 0) return

      // Build tab bar
      const tabBar = document.createElement('div')
      tabBar.className = 'derivation-tabs'
      tabBar.setAttribute('role', 'tablist')

      const tabOverview = document.createElement('button')
      tabOverview.className = 'derivation-tab derivation-tab--active'
      tabOverview.setAttribute('role', 'tab')
      tabOverview.setAttribute('aria-selected', 'true')
      tabOverview.setAttribute('id', 'tab-overview')
      tabOverview.setAttribute('aria-controls', 'panel-overview')
      tabOverview.textContent = 'Overview'

      const tabDerivation = document.createElement('button')
      tabDerivation.className = 'derivation-tab'
      tabDerivation.setAttribute('role', 'tab')
      tabDerivation.setAttribute('aria-selected', 'false')
      tabDerivation.setAttribute('id', 'tab-derivation')
      tabDerivation.setAttribute('aria-controls', 'panel-derivation')
      tabDerivation.textContent = 'Derivation'

      tabBar.appendChild(tabOverview)
      tabBar.appendChild(tabDerivation)

      // Build panels
      const panelOverview = document.createElement('div')
      panelOverview.className = 'derivation-panel derivation-panel--active'
      panelOverview.setAttribute('role', 'tabpanel')
      panelOverview.setAttribute('id', 'panel-overview')
      panelOverview.setAttribute('aria-labelledby', 'tab-overview')

      const panelDerivation = document.createElement('div')
      panelDerivation.className = 'derivation-panel'
      panelDerivation.setAttribute('role', 'tabpanel')
      panelDerivation.setAttribute('id', 'panel-derivation')
      panelDerivation.setAttribute('aria-labelledby', 'tab-derivation')
      panelDerivation.hidden = true

      // Move nodes into panels
      for (const node of overviewNodes) panelOverview.appendChild(node)
      for (const node of derivationNodes) panelDerivation.appendChild(node)

      // Insert tab bar and panels before the Enables section (or at end)
      const enablesDiv = children[slotEnd] || null
      article.insertBefore(tabBar, enablesDiv)
      article.insertBefore(panelOverview, enablesDiv)
      article.insertBefore(panelDerivation, enablesDiv)

      // Tab switching
      function switchTab(activeId) {
        const isOverview = activeId === 'overview'

        tabOverview.classList.toggle('derivation-tab--active', isOverview)
        tabOverview.setAttribute('aria-selected', String(isOverview))
        tabDerivation.classList.toggle('derivation-tab--active', !isOverview)
        tabDerivation.setAttribute('aria-selected', String(!isOverview))

        panelOverview.classList.toggle('derivation-panel--active', isOverview)
        panelOverview.hidden = !isOverview
        panelDerivation.classList.toggle('derivation-panel--active', !isOverview)
        panelDerivation.hidden = isOverview
      }

      tabOverview.addEventListener('click', () => switchTab('overview'))
      tabDerivation.addEventListener('click', () => switchTab('derivation'))

      // Handle URL hash targeting derivation content
      function handleHash() {
        const hash = window.location.hash
        if (!hash) return
        const target = document.getElementById(hash.slice(1))
        if (!target) return
        if (panelDerivation.contains(target)) {
          switchTab('derivation')
          requestAnimationFrame(() => target.scrollIntoView({ behavior: 'smooth' }))
        } else if (panelOverview.contains(target)) {
          switchTab('overview')
          requestAnimationFrame(() => target.scrollIntoView({ behavior: 'smooth' }))
        }
      }

      handleHash()
      window.addEventListener('hashchange', handleHash)
    })()
  </script>
)}

<style>
  header {
    margin-bottom: 2rem;
  }
</style>
