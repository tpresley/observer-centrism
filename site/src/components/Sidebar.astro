---
import { getCollection } from 'astro:content'

interface Props {
  currentPath: string
}

const { currentPath } = Astro.props
const base = import.meta.env.BASE_URL.replace(/\/$/, '')

const sourceEntries = await getCollection('source')
const derivationEntries = await getCollection('derivations')
const predictionEntries = await getCollection('predictions')
const guideEntries = await getCollection('guide')

const sortedGuide = guideEntries.sort((a, b) => a.data.order - b.data.order)

const sortedSource = sourceEntries.sort((a, b) => a.data.order - b.data.order)

/** Strip base prefix from path for comparison */
const pathWithoutBase = currentPath.startsWith(base) ? (currentPath.slice(base.length) || '/') : currentPath

/** Normalize trailing slashes and compare */
function isActive(href: string): boolean {
  const norm = (s: string) => s.replace(/\/+$/, '') || '/'
  return norm(pathWithoutBase) === norm(href)
}

const isSourcePage = pathWithoutBase.startsWith('/source/')

const derivationGroups = {
  'Foundation': derivationEntries.filter(d => d.data.tags.includes('foundation')),
  'Dynamics': derivationEntries.filter(d => d.data.tags.includes('dynamics')),
  'Geometry': derivationEntries.filter(d => d.data.tags.includes('geometry')),
  'Quantum': derivationEntries.filter(d => d.data.tags.includes('quantum')),
  'Particles': derivationEntries.filter(d => d.data.tags.includes('particles')),
  'Holography': derivationEntries.filter(d => d.data.tags.includes('holography')),
  'Gauge': derivationEntries.filter(d => d.data.tags.includes('gauge')),
  'Flavor': derivationEntries.filter(d => d.data.tags.includes('flavor')),
  'Cosmology': derivationEntries.filter(d => d.data.tags.includes('cosmology')),
  'Thermo Extensions': derivationEntries.filter(d => d.data.tags.includes('thermo-ext')),
}

function statusIcon(status: string) {
  switch(status) {
    case 'rigorous': return '●'
    case 'provisional': return '◐'
    case 'draft': return '○'
    case 'stub': return '·'
    case 'non-viable': return '✗'
    default: return '·'
  }
}

function statusColor(status: string) {
  switch(status) {
    case 'rigorous': return 'var(--color-rigorous)'
    case 'provisional': return 'var(--color-provisional)'
    case 'draft': return 'var(--color-draft)'
    case 'stub': return 'var(--color-stub)'
    case 'non-viable': return 'var(--color-non-viable)'
    default: return 'var(--color-stub)'
  }
}
---

<nav class="sidebar" aria-label="Main navigation">
  <div class="site-title">Observer-Centrism</div>
  <div class="site-subtitle">Physics from Three Axioms</div>

  <a href={`${base}/`} aria-current={isActive('/') ? 'page' : undefined}>Home</a>
  <a href={`${base}/map`} aria-current={isActive('/map') ? 'page' : undefined}>Derivation Map</a>
  <a href={`${base}/postulates`} aria-current={isActive('/postulates') ? 'page' : undefined}>Structural Postulates</a>
  <a href={`${base}/search`} aria-current={isActive('/search') ? 'page' : undefined}>Search</a>
  <a href={`${base}/sitemap`} aria-current={isActive('/sitemap') ? 'page' : undefined}>Site Map</a>

  <h2>Guide</h2>
  <a href={`${base}/guide/`} aria-current={isActive('/guide/') ? 'page' : undefined}>Overview</a>
  {sortedGuide.map(entry => (
    <a href={`${base}/guide/${entry.slug}`} aria-current={isActive(`/guide/${entry.slug}`) ? 'page' : undefined}>
      {entry.data.order}. {entry.data.title}
    </a>
  ))}

  <h2>Derivations</h2>
  <a href={`${base}/derivations/`} aria-current={isActive('/derivations/') ? 'page' : undefined}>Index</a>
  {Object.entries(derivationGroups).map(([group, entries]) => (
    entries.length > 0 && (
      <>
        <div class="sidebar-group-label">{group}</div>
        {entries.map(entry => (
          <a href={`${base}/derivations/${entry.slug}`} aria-current={isActive(`/derivations/${entry.slug}`) ? 'page' : undefined}>
            <span style={`color: ${statusColor(entry.data.status)}`}>{statusIcon(entry.data.status)}</span>
            {' '}{entry.data.title}
          </a>
        ))}
      </>
    )
  ))}

  <h2>Predictions</h2>
  <a href={`${base}/predictions/`} aria-current={isActive('/predictions/') ? 'page' : undefined}>Overview</a>
  {predictionEntries.map(entry => (
    <a href={`${base}/predictions/${entry.slug}`} aria-current={isActive(`/predictions/${entry.slug}`) ? 'page' : undefined}>{entry.data.title}</a>
  ))}

  <details class="sidebar-details" open={isSourcePage || undefined}>
    <summary><h2>Source Document</h2></summary>
    {sortedSource.map(entry => (
      <a href={`${base}/source/${entry.slug}`} aria-current={isActive(`/source/${entry.slug}`) ? 'page' : undefined}>{entry.data.section}. {entry.data.title}</a>
    ))}
  </details>
</nav>

<style>
  .sidebar-group-label {
    font-size: 0.7rem;
    text-transform: uppercase;
    color: var(--color-text-muted);
    padding: 0.5rem 0.5rem 0.15rem;
    letter-spacing: 0.04em;
  }
  .sidebar-details {
    margin: 0;
  }
  .sidebar-details summary {
    cursor: pointer;
    list-style: none;
  }
  .sidebar-details summary::-webkit-details-marker {
    display: none;
  }
  .sidebar-details summary h2 {
    display: inline;
  }
  .sidebar-details summary h2::after {
    content: ' \25B6';
    font-size: 0.5rem;
    vertical-align: middle;
    color: var(--color-text-muted);
  }
  .sidebar-details[open] summary h2::after {
    content: ' \25BC';
  }
</style>
