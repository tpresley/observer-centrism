    border-top: 1px solid var(--color-border);
    padding-top: 1.5rem;
  }

  .nothing-article h2:first-of-type {
    border-top: none;
    padding-top: 0;
  }

  .nothing-article p {
    margin-bottom: 1rem;
    line-height: 1.85;
  }

  .nothing-article ul {
    margin-bottom: 1.25rem;
    padding-left: 1.5rem;
  }

  .nothing-article li {
    margin-bottom: 0.75rem;
    line-height: 1.75;
  }

  .lead {
    font-size: 1.05rem;
    line-height: 1.8;
    color: var(--color-text-muted);
    margin-bottom: 2rem;
  }

  .nothing-links {
    margin-top: 2.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-border);
    text-align: center;
    font-size: 0.9rem;
  }

  .nothing-links a {
    color: var(--color-accent);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: border-color 0.15s;
  }

  .nothing-links a:hover {
    border-bottom-color: var(--color-accent);
  }
</style>
