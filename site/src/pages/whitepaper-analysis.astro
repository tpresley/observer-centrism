  }
  .wa-stat-label {
    font-size: 0.65rem;
    text-transform: uppercase;
    color: var(--color-text-muted);
    letter-spacing: 0.04em;
  }
  .wa-stat-value {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-text);
  }

  .wa-card {
    border: 1px solid var(--color-border);
    border-radius: 8px;
